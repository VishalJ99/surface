{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://surface-app.local/contracts/thread-summaries-v1.schema.json",
  "title": "Surface Thread Summaries v1",
  "type": "object",
  "required": [
    "contract",
    "status",
    "generated_at",
    "source_contract",
    "source_path",
    "provider",
    "account",
    "selection_mode",
    "llm_backend",
    "llm_model",
    "thread_summary_count",
    "thread_summaries",
    "chunk_count",
    "failed_chunk_count",
    "chunk_results"
  ],
  "properties": {
    "contract": {
      "const": "surface.thread_summaries.v1"
    },
    "status": {
      "enum": [
        "complete",
        "partial",
        "failed"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "source_contract": {
      "type": "string"
    },
    "source_path": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "account": {
      "type": "string"
    },
    "selection_mode": {
      "type": "string"
    },
    "search_query": {
      "type": [
        "string",
        "null"
      ]
    },
    "llm_backend": {
      "type": "string"
    },
    "llm_model": {
      "type": "string"
    },
    "source_email_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_thread_count": {
      "type": "integer",
      "minimum": 0
    },
    "thread_summary_count": {
      "type": "integer",
      "minimum": 0
    },
    "thread_summaries": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "chunk_count": {
      "type": "integer",
      "minimum": 0
    },
    "failed_chunk_count": {
      "type": "integer",
      "minimum": 0
    },
    "chunk_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chunk_result"
      }
    },
    "output_path": {
      "type": "string"
    }
  },
  "$defs": {
    "chunk_result": {
      "type": "object",
      "required": [
        "chunk_index",
        "status",
        "conversation_ids",
        "summary_count"
      ],
      "properties": {
        "chunk_index": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "enum": [
            "ok",
            "partial",
            "failed"
          ]
        },
        "conversation_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary_count": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_input_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "prompt_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "completion_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "total_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "oversized_single_thread": {
          "type": "boolean"
        },
        "missing_conversation_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unexpected_conversation_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error": {
          "type": "string"
        },
        "raw_response_path": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
