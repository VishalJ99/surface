# Optional LLM post-processing for derived thread summaries.
# Current implementation supports OpenRouter. The other API key names are
# reserved for future backends and are documented here for visibility.

OPENROUTER_API_KEY=
SURFACE_POST_PROCESS_BACKEND=openrouter
SURFACE_POST_PROCESS_MODEL=qwen/qwen3.5-397b-a17b

# Planned future backends:
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
